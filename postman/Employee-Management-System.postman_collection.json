{
  "info": {
    "name": "Employee Management System API",
    "description": "Postman collection for testing the Spring Boot Employee Management System REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "employeeId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Create Employee",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Amit\",\n  \"lastName\": \"Gupta\",\n  \"email\": \"amit.gupta@example.com\",\n  \"department\": \"IT\",\n  \"salary\": 65000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employees",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees"
          ]
        },
        "description": "Creates a new employee."
      },
      "response": []
    },
    {
      "name": "Get All Employees",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees"
          ]
        },
        "description": "Returns all employees."
      },
      "response": []
    },
    {
      "name": "Get Employee By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees",
            "{{employeeId}}"
          ]
        },
        "description": "Returns an employee by ID."
      },
      "response": []
    },
    {
      "name": "Update Employee",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Amit\",\n  \"lastName\": \"Gupta\",\n  \"email\": \"amit.updated@example.com\",\n  \"department\": \"HR\",\n  \"salary\": 72000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees",
            "{{employeeId}}"
          ]
        },
        "description": "Updates an existing employee."
      },
      "response": []
    },
    {
      "name": "Delete Employee",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees",
            "{{employeeId}}"
          ]
        },
        "description": "Deletes an employee by ID."
      },
      "response": []
    },
    {
      "name": "Search Employee By Department",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees/search?department=IT",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employees",
            "search"
          ],
          "query": [
            {
              "key": "department",
              "value": "IT"
            }
          ]
        },
        "description": "Searches employees by department."
      },
      "response": []
    }
  ]
}
